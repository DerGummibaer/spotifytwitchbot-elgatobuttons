# Copy this file to ".env" and fill in your real values.
# Never share your .env file or paste its contents anywhere.

# --- Twitch ---
# Get all three values from https://twitchtokengenerator.com (Bot Chat Token)
# Paste WITHOUT the "oauth:" prefix -- the bot adds it automatically.
# Having TWITCH_REFRESH_TOKEN and TWITCH_CLIENT_ID set lets the bot
# automatically renew its token when it expires without manual intervention.
TWITCH_OAUTH_TOKEN=your_twitch_token_here
TWITCH_REFRESH_TOKEN=your_refresh_token_here
TWITCH_CLIENT_ID=your_client_id_here

# The Twitch account the bot logs in AS (often your own account, or a bot account)
TWITCH_BOT_USERNAME=your_bot_account_username

# The channel to join (your channel, lowercase, no #)
TWITCH_CHANNEL=senzrrr

# Your own Twitch username, so the bot recognizes you as broadcaster
TWITCH_BROADCASTER_USERNAME=senzrrr

# --- Spotify service connection ---
# Must match CONTROL_HOST / CONTROL_PORT in the spotify-service project's
# own .env file -- these are two separate programs that need to agree on
# where the service is listening.
SERVICE_HOST=127.0.0.1
SERVICE_PORT=9876
