# Copy this file to ".env" and fill in your real values.
# Never share your .env file or paste its contents anywhere.

# --- Spotify ---
# Get from https://developer.spotify.com/dashboard (Client ID only, PKCE flow)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- Local control socket ---
# Stream Deck and the Twitch bot both connect here. If you change this,
# update CONTROL_PORT in the Twitch bot's .env too, and the hardcoded
# port in the Stream Deck plugin's src/bot-client.ts.
CONTROL_HOST=127.0.0.1
CONTROL_PORT=9876
